$customVar = require v              # --customVar must be provided by user (a literal string)
$id = letter digit 1..
$isd = letter digit 0..
$sdf = letter 0..
$name = not letter digit 1..5
$a = $customVar
$c = $customVar 10
$empty = ( ( ("") ) ) #test

pattern: 
letter 1
# ("") 1 #test
# (((("")))) 1 #test
# "" 1 #test
# axxx { "" } #test
# digit 0.. #test
# digit 1.. #test
# $empty #test
# $empty 1 #test
("") #test | should be removed by resolver
"" #test | should be removed by resolver
((("")))
$empty
# testEmpty { $empty }
# testEmpty { ( ("") ) } #test

$sdf
$id
$isd
$c
$name

name {
  digit 1..5 
  letter 3..4
  $id
}

smth { $a }

( whitespace 1..5 | whitespace 3.. | "" ) 

$customVar 
[a..h 4..5 4..9 a..z] 
not [a . s d 1..9 digit space \]  \[ [ ] 123 
@phone
@email 
#whitespace 1..
#['asd ' digit]
tab
"\\'abc" 1..
"a"
