$customVar = require v              # --customVar must be provided by user (a literal string)
$id = letter digit* 
$name = not letter digit 1-5
$a = $customVar

pattern:

$name
capture phone (
  digit 1-5 
  letter 3-3
  $id
)
capture smth ($a)

(
  whitespace 1-5 |
  whitespace 3- |
  a b
) 

$customVar 
[a-h 4-5 4-9 a-z]
not [a . s d 1-9 digit space \]  \[ [ ] 123 
@phone
@email 
whitespace* 
#['asd ' digit]

"\t'abc"+

